{
  "name": "trgger",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "commit": "cz",
    "release": "semantic-release",
    "lint": "pnpm lint:style && pnpm lint:type && pnpm lint:script",
    "lint:type": "vue-tsc --pretty --noEmit",
    "lint:script": "eslint --ext .ts,.tsx,.vue --ignore-path .gitignore .",
    "lint:style": "stylelint **/*.{css,vue}",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "update-db-types": "supabase gen types typescript --project-id \"$SUPABASE_PROJECT_ID\" > src/db.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7",
    "vue": "^3.4.15"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@stylistic/eslint-plugin": "^1.6.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/vue": "^8.0.2",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vitest/coverage-istanbul": "^1.3.1",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.0.1",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-n": "^15.0.0 || ^16.0.0 ",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-vue": "^9.21.1",
    "happy-dom": "^13.3.8",
    "husky": "^9.0.11",
    "postcss-html": "^1.6.0",
    "semantic-release": "^23.0.2",
    "stylelint": "^16.2.1",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "vitest": "^1.3.1",
    "vue-tsc": "^1.8.27"
  }
}
